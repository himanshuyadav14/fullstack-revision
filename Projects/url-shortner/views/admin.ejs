<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - All URLs</title>
    <style>
      body {
        font-family: tahoma;
        margin: 20px;
      }

      h1 {
        color: #333;
      }

      table {
        border-collapse: collapse;
        margin-top: 20px;
        width: 100%;
        max-width: 1100px;
      }

      th,
      td {
        border: 1px solid #ccc;
        padding: 8px;
        text-align: left;
      }
    </style>
  </head>
  <body>
    <h1>Admin Dashboard — All URLs</h1>
    <p><a href="/">← Back to Home</a></p>

    <% if (locals.urls && urls.length) { %>
    <table>
      <thead>
        <tr>
          <th>S. No</th>
          <th>Short ID</th>
          <th>Original URL</th>
          <th>Owner</th>
          <th>Clicks</th>
          <th>Created At</th>
        </tr>
      </thead>
      <tbody>
        <% urls.forEach((url, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= url.shortId %></td>
          <td><%= url.redirectUrl %></td>
          <td><%= url.createdBy?.name %> (<%= url.createdBy?.email %>)</td>
          <td><%= url.visitHistory.length %></td>
          <td><%= url.createdAt?.toLocaleString() %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } else { %>
    <p>No URLs found.</p>
    <% } %>
  </body>
</html>
