<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>URL Shortener</title>
    <style>
      body {
        font-family: tahoma;
        margin: 20px;
      }

      h1 {
        color: #333;
      }

      .error {
        color: #b00020;
      }

      .success {
        color: #1b5e20;
      }

      table {
        border-collapse: collapse;
        margin-top: 20px;
        width: 100%;
        max-width: 900px;
      }

      th,
      td {
        border: 1px solid #ccc;
        padding: 8px;
        text-align: left;
      }
    </style>
  </head>

  <body>
    <h1>URL Shortener</h1>

    <% if (locals.role === "admin") { %>
    <p><a href="/admin/urls">Admin Dashboard</a></p>
    <% } %>

    <% if (locals.id) { %>
    <h2>
      Your Short URL is:
      <a href="/url/<%= id %>">http://localhost:3000/url/<%= id %></a>
    </h2>
    <% } %>

    <% if (locals.error) { %>
    <p class="error"><%= error %></p>
    <% } %>

    <% if (locals.success) { %>
    <p class="success"><%= success %></p>
    <% } %>

    <div>
      <form action="/user/logout" method="post">
        <button type="submit">Logout</button>
      </form>
      <form method="POST" action="/url">
        <label for="url">Enter your original URL</label>
        <input
          type="url"
          id="url"
          name="url"
          placeholder="https://example.com"
          required
        />
        <button type="submit">Generate</button>
      </form>
    </div>

    <% if (locals.urls && urls.length) { %>
    <table>
      <thead>
        <tr>
          <th>S. No</th>
          <th>Short ID</th>
          <th>Original URL</th>
          <th>Clicks</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% urls.forEach((url, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td>
            <a href="/url/<%= url.shortId %>"><%= url.shortId %></a>
          </td>
          <td><%= url.redirectUrl %></td>
          <td><%= url.visitHistory.length %></td>
          <td>
            <form method="POST" action="/url/<%= url.shortId %>/delete">
              <button type="submit">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </body>
</html>
