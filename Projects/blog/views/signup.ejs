<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/header") %>
    <link rel="stylesheet" href="/css/auth.css" />
    <title>Sign up | Blogify</title>
  </head>
  <body>
    <%- include("partials/nav") %>

    <main class="auth-page">
      <div class="auth-card">
        <div class="auth-badge">B</div>
        <h1 class="auth-title">Create your account</h1>
        <p class="auth-subtitle">
          Join Blogify and start sharing your stories with the world.
        </p>

        <% if (locals.error) { %>
        <div class="auth-alert" role="alert"><%= error %></div>
        <% } %>

        <form class="auth-form" action="/user/signup" method="post">
          <div class="mb-3">
            <label for="fullName" class="form-label">Full name</label>
            <input
              type="text"
              class="form-control"
              id="fullName"
              name="fullName"
              placeholder="Himanshu Yadav"
              required
            />
          </div>
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input
              type="email"
              class="form-control"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
            />
          </div>
          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input
              type="password"
              class="form-control"
              id="password"
              name="password"
              placeholder="Create a strong password"
              required
            />
          </div>
          <button type="submit" class="btn site-btn-primary auth-submit">
            Create account
          </button>
        </form>

        <p class="auth-footer">
          Already have an account?
          <a href="/user/signin">Sign in</a>
        </p>
      </div>
    </main>

    <%- include("partials/scripts") %>
  </body>
</html>
