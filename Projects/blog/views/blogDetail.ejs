<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/header") %>
    <link rel="stylesheet" href="/css/home.css" />
    <title><%= locals.blog ? blog.title + " | Blogify" : "Blog not found | Blogify" %></title>
  </head>
  <body>
    <%- include("partials/nav") %>

    <main class="container py-4">
      <a href="/" class="back-link">&larr; Back to home</a>

      <% if (locals.error) { %>
      <div class="blog-not-found">
        <h1>Blog not found</h1>
        <p>The post you are looking for does not exist or was removed.</p>
        <a href="/" class="btn btn-primary">Go to homepage</a>
      </div>
      <% } else { %>
      <article class="blog-detail">
        <img
          src="/<%= blog.coverImageUrl %>"
          alt="<%= blog.title %> cover"
          class="blog-detail-cover"
          onerror="this.src='/images/user.png'"
        />
        <div class="blog-detail-content">
          <h1 class="blog-detail-title"><%= blog.title %></h1>
          <div class="blog-detail-meta">
            <div class="blog-author">
              <img
                src="<%= blog.createdBy?.profileImageUrl || '/images/user.png' %>"
                alt="<%= blog.createdBy?.fullName || 'Author' %>"
              />
              <span><%= blog.createdBy?.fullName || "Unknown author" %></span>
            </div>
            <time datetime="<%= blog.createdAt %>">
              <%= new Date(blog.createdAt).toLocaleDateString("en-IN", {
                day: "numeric",
                month: "long",
                year: "numeric",
              }) %>
            </time>
          </div>
          <div class="blog-detail-body"><%= blog.body %></div>
        </div>
      </article>

      <section class="comments-section" id="comments">
        <div class="comments-header">
          <h2>Comments</h2>
          <span class="comments-count"><%= comments.length %></span>
        </div>

        <% if (locals.user) { %>
        <form
          class="comment-form"
          action="/blog/<%= blog._id %>/comment"
          method="post"
        >
          <label for="content" class="form-label fw-semibold">Add a comment</label>
          <textarea
            class="form-control comment-textarea"
            id="content"
            name="content"
            rows="3"
            placeholder="Share your thoughts..."
            required
          ></textarea>
          <button type="submit" class="btn site-btn-primary mt-3">Post comment</button>
        </form>
        <% } else { %>
        <div class="comment-signin-prompt">
          <p>Sign in to join the conversation.</p>
          <a href="/user/signin" class="btn site-btn-primary btn-sm">Sign in</a>
        </div>
        <% } %>

        <div class="comments-list">
          <% if (comments.length === 0) { %>
          <p class="comments-empty">No comments yet. Be the first to comment!</p>
          <% } else { %>
          <% comments.forEach((comment) => { %>
          <article class="comment-card">
            <img
              src="<%= comment.createdBy?.profileImageUrl || '/images/user.png' %>"
              alt="<%= comment.createdBy?.fullName || 'User' %>"
              class="comment-avatar"
            />
            <div class="comment-body">
              <div class="comment-meta">
                <strong><%= comment.createdBy?.fullName || "Unknown user" %></strong>
                <time datetime="<%= comment.createdAt %>">
                  <%= new Date(comment.createdAt).toLocaleDateString("en-IN", {
                    day: "numeric",
                    month: "short",
                    year: "numeric",
                  }) %>
                </time>
              </div>
              <p class="comment-content"><%= comment.content %></p>
            </div>
          </article>
          <% }); %>
          <% } %>
        </div>
      </section>
      <% } %>
    </main>

    <footer class="site-footer">
      <div class="container">&copy; <%= new Date().getFullYear() %> Blogify</div>
    </footer>

    <%- include("partials/scripts") %>
  </body>
</html>
