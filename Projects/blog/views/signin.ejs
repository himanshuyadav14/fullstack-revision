<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/header") %>
    <link rel="stylesheet" href="/css/auth.css" />
    <title>Sign in | Blogify</title>
  </head>
  <body>
    <%- include("partials/nav") %>

    <main class="auth-page">
      <div class="auth-card">
        <div class="auth-badge">B</div>
        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-subtitle">Sign in to continue reading and writing on Blogify.</p>

        <% if (locals.error) { %>
        <div class="auth-alert" role="alert"><%= error %></div>
        <% } %>

        <form class="auth-form" action="/user/signin" method="post">
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input
              type="email"
              class="form-control"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
            />
          </div>
          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input
              type="password"
              class="form-control"
              id="password"
              name="password"
              placeholder="Enter your password"
              required
            />
          </div>
          <button type="submit" class="btn site-btn-primary auth-submit">
            Sign in
          </button>
        </form>

        <p class="auth-footer">
          Don't have an account?
          <a href="/user/signup">Create one</a>
        </p>
      </div>
    </main>

    <%- include("partials/scripts") %>
  </body>
</html>
