<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/header") %>
    <link rel="stylesheet" href="/css/home.css" />
    <title>Home | Blogify</title>
  </head>
  <body>
    <%- include("partials/nav") %>

    <section class="home-hero">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-8">
            <% if (locals.user) { %>
            <p class="mb-2 text-white-50">Welcome back,</p>
            <h1 class="display-5 mb-3"><%= user.fullName %></h1>
            <p class="mb-4">
              Discover stories from the community or share your own ideas with the
              world.
            </p>
            <a href="/blog/add-blog" class="btn btn-light">Write a new blog</a>
            <% } else { %>
            <h1 class="display-5 mb-3">Read. Write. Share.</h1>
            <p class="mb-4">
              Blogify is your space to explore thoughtful posts and publish your
              own stories in minutes.
            </p>
            <a href="/user/signup" class="btn btn-light me-2">Get started</a>
            <a href="/user/signin" class="btn btn-outline-light">Sign in</a>
            <% } %>
          </div>
        </div>
      </div>
    </section>

    <main class="container pb-4">
      <div class="d-flex align-items-center justify-content-between mb-2">
        <h2 class="section-heading mb-0">Latest blogs</h2>
        <span class="text-muted"><%= blogs.length %> post<%= blogs.length === 1 ? "" : "s" %></span>
      </div>

      <% if (blogs.length === 0) { %>
      <div class="empty-state">
        <h3>No blogs yet</h3>
        <p>Be the first to publish something worth reading.</p>
        <% if (locals.user) { %>
        <a href="/blog/add-blog" class="btn btn-primary">Create your first blog</a>
        <% } else { %>
        <a href="/user/signup" class="btn btn-primary">Join Blogify</a>
        <% } %>
      </div>
      <% } else { %>
      <div class="row g-4">
        <% blogs.forEach((blog) => { %>
        <div class="col-md-6 col-lg-4">
          <a href="/blog/<%= blog._id %>" class="blog-card-link">
            <article class="blog-card">
              <img
                src="/<%= blog.coverImageUrl %>"
                alt="<%= blog.title %> cover"
                class="blog-card-img"
                onerror="this.src='/images/user.png'"
              />
              <div class="blog-card-body">
                <h3 class="blog-card-title"><%= blog.title %></h3>
                <p class="blog-card-excerpt">
                  <%= blog.body.length > 130 ? blog.body.substring(0, 130) + "..." : blog.body %>
                </p>
                <div class="blog-card-meta">
                  <div class="blog-author">
                    <img
                      src="<%= blog.createdBy?.profileImageUrl || '/images/user.png' %>"
                      alt="<%= blog.createdBy?.fullName || 'Author' %>"
                    />
                    <span><%= blog.createdBy?.fullName || "Unknown author" %></span>
                  </div>
                  <time datetime="<%= blog.createdAt %>">
                    <%= new Date(blog.createdAt).toLocaleDateString("en-IN", {
                      day: "numeric",
                      month: "short",
                      year: "numeric",
                    }) %>
                  </time>
                </div>
              </div>
            </article>
          </a>
        </div>
        <% }); %>
      </div>
      <% } %>
    </main>

    <footer class="site-footer">
      <div class="container">&copy; <%= new Date().getFullYear() %> Blogify</div>
    </footer>

    <%- include("partials/scripts") %>
  </body>
</html>
